publish/

# Publish Web Output
*.[Pp]ublish.xml
*.azurePubxml
**/*.PublishingProfile

# TODO: Un-comment the next line if you do not want to checkin
# your /packages directory to source control.
#packages/*

# NuGet v3's project.json files produces more ignorable folder for us
**/[Pp]ackages/*
!**/[Pp]ackages/build/
!**/[Pp]ackages/repositories.config
!**/packages/*.props
!**/packages/*.targets

