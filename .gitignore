beatpulse.db

# Backup folder for Package Reference Convert tool in Visual Studio 2017
MigrationBackup/

# Ionide (cross platform F# VS Code tools) working folder
.ionide/

# Ionide Project
.ionide/*.ionide

# Fody - auto-generated XML schema file
*.Fody.props

# VS Code files for those working on multiple tools
.vscode-test/**
!.vscode-test/settings.json

# Local History for Visual Studio Code
.localhistory/

# Windows Container Tools for Visual Studio
# Publish set profile template
pubxml.*.bak

# Microsoft Azure Webapp publish settings. Comment the next line if you need to
# checkin publish profile settings for publishing from the command line
*.pubxml
# Do not ignore pubxml for Azure Functions projects, these files are required during publishing.
!**Functions/**/*.pubxml

# Microsoft Azure Pipelines
.pipelines/

# .NET Core launchsettings.json is only for local development, so it should be ignored
# https://docs.microsoft.com/dotnet/core/tools/dotnet-run#options
launchSettings.json

# .NET Core run profile folders
/Properties/launchSettings.json

# .NET Core run configurations
.runsettings

# JetBrains Rider
.idea/
*.sln.iml

# PyCharm
.idea/

# Frameworks
packages/

# Entity Framework Migrations
**/Migrations/*.cs

# Windows Thurderbird .mozfiles
*.[Mm]ozSite

# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
[Dd]esktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# macOS
.DS_Store

